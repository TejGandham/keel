<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Repo Man">
      {assigns[:page_title]}
    </.live_title>
    <script>
      // Set data-theme before first paint to prevent flash of wrong theme.
      // Reads localStorage, falls back to prefers-color-scheme, defaults to dark.
      (function() {
        var t = localStorage.getItem('theme');
        if (!t) t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <style>
      /* F28: Dark-first theme, togglable via data-theme attribute */
      :root {
        font-family: -apple-system, 'Inter', ui-sans-serif, system-ui, sans-serif;
      }

      :root[data-theme="dark"] {
        --bg-page: #0a0a0a;
        --text-page: #fafafa;
      }

      :root[data-theme="light"] {
        --bg-page: #fafafa;
        --text-page: #171717;
      }

      body {
        background-color: var(--bg-page);
        color: var(--text-page);
        margin: 0;
      }

      /* Spin animation for in-progress card spinners */
      @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }
    </style>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
